# pantry-armv6.config — Kconfig fragment for the stripped Pantry Host kernel.
#
# Merged on top of `bcm2835_defconfig` (the lean BCM2835 / ARMv6 base) with
#   scripts/kconfig/merge_config.sh -m .config <this>
# then resolved with `make olddefconfig`. See kernel/build-kernel.sh.
#
# Goal: pull WiFi + root storage init into the *kernel boot* (built-in, =y)
# instead of a ~25s-late udev modprobe, so the single ARMv6 core associates
# WiFi ~20s sooner. Everything a headless kitchen server never touches is
# stripped to shrink the image and cut coldplug/decompress on the slow core.
#
# Contingency: if bcm2835_defconfig turns out to lack the RPi-specific SDIO /
# brcmfmac bindings, rebase on bcmrpi_defconfig (RPi's downstream ARMv6 config)
# and keep this same =y/strip intent. Always sanity-check the resulting
# .config against the device's `lsmod` before shipping.

# --- Module identity -------------------------------------------------------
# Own /lib/modules dir so the stock kernel + its modules stay intact for
# rollback (we boot kernel-pantry.img; stock kernel.img is the fallback).
CONFIG_LOCALVERSION="-pantry-v6"
# CONFIG_LOCALVERSION_AUTO is not set

# --- Kernel image compression ---------------------------------------------
# LZ4 decompresses far faster than gzip/xz on a single 1 GHz ARMv6 core; the
# few hundred KB of extra image size is irrelevant next to the boot-time win.
CONFIG_KERNEL_LZ4=y
# CONFIG_KERNEL_GZIP is not set
# CONFIG_KERNEL_XZ is not set

# --- Root storage: SD / MMC (built-in so rootfs mounts with no initramfs) ---
CONFIG_MMC=y
CONFIG_MMC_BLOCK=y
CONFIG_MMC_BCM2835=y
CONFIG_MMC_BCM2835_DMA=y
# RPi's downstream sdhost controller (the fast path on a Zero W).
CONFIG_MMC_SDHCI=y
CONFIG_MMC_SDHCI_IPROC=y
CONFIG_MMC_BCM2835_SDHOST=y

# --- Root filesystem + boot (FAT) partition --------------------------------
CONFIG_EXT4_FS=y
CONFIG_EXT4_USE_FOR_EXT2=y
CONFIG_JBD2=y
CONFIG_VFAT_FS=y
CONFIG_FAT_DEFAULT_CODEPAGE=437
CONFIG_NLS=y
CONFIG_NLS_CODEPAGE_437=y
CONFIG_NLS_ISO8859_1=y
CONFIG_NLS_ASCII=y

# --- WiFi stack: built-in end to end ---------------------------------------
# The whole point: brcmfmac + its SDIO transport and the cfg80211/mac80211
# core all initialize during kernel boot, not via a late modprobe.
CONFIG_CFG80211=y
CONFIG_MAC80211=y
CONFIG_WIRELESS=y
CONFIG_WLAN=y
CONFIG_WLAN_VENDOR_BROADCOM=y
CONFIG_BRCMUTIL=y
CONFIG_BRCMFMAC=y
CONFIG_BRCMFMAC_PROTO_BCDC=y
CONFIG_BRCMFMAC_SDIO=y
# SDIO/MMC bus glue brcmfmac rides on.
CONFIG_MMC_SDIO_UART=n

# rfkill is LOAD-BEARING — must stay built-in. The wiphy registers an rfkill
# instance and the image's WiFi-unblock fix (customize.sh: WirelessEnabled=true
# in NetworkManager.state) is built around NetworkManager owning that
# soft-block. Modularizing or dropping rfkill can leave WiFi soft-blocked.
# Built-in also means the rfkill device exists at early boot, so NM unblocks
# it the instant it starts — reinforcing the earlier bring-up.
CONFIG_RFKILL=y
CONFIG_RFKILL_INPUT=y

# Keep the regulatory domain working: the image passes
# cfg80211.ieee80211_regdom=US on the kernel cmdline. Match the stock config's
# built-in regdb handling so the legal 2.4 GHz channels + tx power apply before
# wlan0 comes up. (Leave CONFIG_CFG80211_REQUIRE_SIGNED_REGDB at the base
# default; olddefconfig keeps the stock choice.)
CONFIG_CFG80211_CRDA_SUPPORT=n

# --- Networking runtime that userspace depends on --------------------------
# Tailscale needs the tun device + netfilter/conntrack/nat for `up`/`serve`;
# NetworkManager and the server use IPv6. Do NOT strip these.
CONFIG_TUN=y
CONFIG_IPV6=y
CONFIG_NETFILTER=y
CONFIG_NETFILTER_ADVANCED=y
CONFIG_NF_CONNTRACK=y
CONFIG_NF_NAT=y
CONFIG_NF_TABLES=y
CONFIG_NF_TABLES_INET=y
CONFIG_NFT_CT=y
CONFIG_NFT_NAT=y
CONFIG_IP_NF_IPTABLES=y
CONFIG_IP_NF_FILTER=y
CONFIG_IP_NF_NAT=y
CONFIG_IP_NF_TARGET_MASQUERADE=y
CONFIG_IP6_NF_IPTABLES=y
CONFIG_IP6_NF_FILTER=y
CONFIG_IP6_NF_NAT=y

# FUSE: present in stock userspace; keep it.
CONFIG_FUSE_FS=y

# --- Console: keep a minimal framebuffer console for tty1 ------------------
# A plugged-in monitor shows the getty login (pantry-console removed). The
# kernel's built-in 8x16 font on the simple framebuffer is enough; the heavy
# KMS/vc4 stack is stripped below.
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_VT=y
CONFIG_VT_CONSOLE=y

# === STRIP — none of this runs on a headless kitchen server ================

# Graphics: full KMS/vc4/3D stack. (config.txt also comments out vc4-kms-v3d.)
# CONFIG_DRM is not set
# CONFIG_DRM_VC4 is not set
# CONFIG_DRM_V3D is not set
# CONFIG_FB_SIMPLE is not set

# Sound.
# CONFIG_SOUND is not set
# CONFIG_SND is not set
# CONFIG_SND_BCM2835 is not set

# Camera / V4L2 / media.
# CONFIG_MEDIA_SUPPORT is not set
# CONFIG_VIDEO_DEV is not set
# CONFIG_VIDEO_BCM2835 is not set
# CONFIG_V4L_PLATFORM_DRIVERS is not set
# CONFIG_DVB_CORE is not set

# USB gadget (Zero W OTG gadget mode — unused as a server).
# CONFIG_USB_GADGET is not set

# Storage we never use: RAID/MD/LVM device-mapper, other filesystems.
# CONFIG_MD is not set
# CONFIG_BLK_DEV_MD is not set
# CONFIG_BTRFS_FS is not set
# CONFIG_XFS_FS is not set
# CONFIG_F2FS_FS is not set
# CONFIG_NTFS_FS is not set
# CONFIG_NTFS3_FS is not set
# CONFIG_REISERFS_FS is not set

# Tracing / debug / profiling — boot-time and size cost, no runtime use here.
# CONFIG_FTRACE is not set
# CONFIG_FUNCTION_TRACER is not set
# CONFIG_KPROBES is not set
# CONFIG_DEBUG_KERNEL is not set
# CONFIG_DEBUG_INFO is not set

# KASLR: not meaningful on this board; skip the relocate cost.
# CONFIG_RANDOMIZE_BASE is not set

# Module compression: small module set; skip the decompress.
# CONFIG_MODULE_COMPRESS_XZ is not set
# CONFIG_MODULE_COMPRESS_ZSTD is not set
